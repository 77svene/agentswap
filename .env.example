# Alchemy WebSocket endpoint (mainnet fork for tests, Sepolia for deploy)
ALCHEMY_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deployer wallet private key (no 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_key

# Chainlink ETH/USD feed (Sepolia)
CHAINLINK_ETH_USD=0x694AA1769357215DE4FAC081bf1f309aDC325306

# Uniswap V3 SwapRouter (Sepolia)
UNISWAP_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564

# Agent and Vault contract addresses (set after deploy)
AGENT_ADDRESS=
VAULT_ADDRESS=

# Backend API port
PORT=3000
